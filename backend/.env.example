# ---- Copy this file to ".env" for local development ----

# Database. Leave as SQLite for local dev; use your Supabase Postgres URL in production.
# Local:
DATABASE_URL=sqlite:///data/local.db
# Supabase (production) example — use the "Connection string" from Supabase > Project Settings > Database:
# DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=please-change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins ("*" allows all — fine for testing).
# In production set this to your Vercel URL, e.g. https://your-app.vercel.app
FRONTEND_ORIGIN=*

# ---- Supabase Storage (for photos / videos / files) ----
# Leave blank for local dev (files are stored in ./uploads instead).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=media

# Real-time engine: "threading" for local dev, "eventlet" in production (Render).
SOCKETIO_ASYNC_MODE=threading
