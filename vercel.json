{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/frontend/index.html", "headers": { "cache-control": "no-cache" } },
    { "src": "/(.*)", "dest": "/frontend/$1", "headers": { "cache-control": "no-cache" } }
  ]
}
